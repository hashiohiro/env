)'\\\"\\n      [marginBottom]=\\\"'var(--usage-tab-item-margin-bottom)'\\\"\\n    >\\n      <ng-container *ngTemplateOutlet=\\\"body\\\"></ng-container>\\n    </app-card>\\n  </ng-template>\\n\\n  <div class=\\\"tab02__body\\\">`;\ntempContent = tempContent.replace(\"  <div class=\\\"tab02__body\\\">\", usageCardTemplate);\nlet templatesBlock = \"\";\nfor (let i = 0; i < templateNames.length; i++) {\n  templatesBlock += `\\n<ng-template #${templateNames[i]}>\\n${cardBodies[i]}\\n</ng-template>\\n`;\n}\nconst finalContent = tempContent + templatesBlock;\nfs.writeFileSync(path, finalContent, { encoding: \"utf8\" });\n'@;\nSet-Content -Path 'refactor_usage_card.js' -Value $script -Encoding UTF8;\nnode refactor_usage_card.js;\nRemove-Item 'refactor_usage_card.js';"]})
