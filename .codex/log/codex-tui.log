 #111111;\r\n    }\r\n\r\n    &:first-child.app-tab__item--active {\r\n      border-top-left-radius: 10px;\r\n    }\r\n\r\n    &:last-child.app-tab__item--active {\r\n      border-top-right-radius: 10px;\r\n    }\r\n  }\r\n\r\n  .app-tab__icon {\r\n    margin-bottom: 1px;\r\n  }\r\n}\r\n\r\n@media (min-width: 768px) {\r\n  .app-tab--tab01 {\r\n    .app-tab__item {\r\n      font-size: 20px;\r\n      padding: 15px;\r\n    }\r\n  }\r\n}\r\n'@"]})
