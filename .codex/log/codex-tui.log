[2m2025-09-23T09:50:24.868434Z[0m [32m INFO[0m FunctionCall: shell({"command":["powershell.exe","-Command","$content = @'\r\nimport { Component, ElementRef, EventEmitter, Input, Output, QueryList, ViewChildren } from '@angular/core';\r\n\r\nexport interface TabItem {\r\n  label: string;\r\n  value: any;\r\n  disabled?: boolean;\r\n  iconUrl?: string;\r\n}\r\n\r\n@Component({\r\n  selector: 'app-tab',\r\n  templateUrl: './tab.component.html',\r\n  styleUrl: './tab.component.scss'\r\n})\r\nexport class TabComponent {\r\n  @Input() tabs: TabItem[] = [];\r\n  @Input() active?: any;\r\n  @Input() variant: 'basic' | 'tab01' = 'basic';\r\n  @Input() ariaLabel?: string;\r\n  @Input() ariaLabelledby?: string;\r\n  @Input() ariaDescribedby?: string;\r\n\r\n  @Output() tabChange = new EventEmitter<any>();\r\n\r\n  @ViewChildren('tabButton') private tabButtons?: QueryList<ElementRef<HTMLButtonElement>>;\r\n\r\n  select(tab: TabItem): void {\r\n    if (tab.disabled) {\r\n      return;\r\n    }\r\n\r\n    this.active = tab.value;\r\n    this.tabChange.emit(tab.value);\r\n  }\r\n\r\n  isActive(tab: TabItem): boolean {\r\n    return this.active === tab.value;\r\n  }\r\n\r\n  onKeyDown(event: KeyboardEvent, index: number): void {\r\n    const tab = this.tabs[index];\r\n    if (!tab || tab.disabled) {\r\n      return;\r\n    }\r\n\r\n    switch (event.key) {\r\n      case ' ':\r\n      case 'Enter':\r\n        event.preventDefault();\r\n        this.select(tab);\r\n        break;\r\n      case 'ArrowLeft':\r\n      case 'Left':\r\n        event.preventDefault();\r\n        this.focusSibling(index, -1);\r\n        break;\r\n      case 'ArrowRight':\r\n      case 'Right':\r\n        event.preventDefault();\r\n        this.focusSibling(index, 1);\r\n        break;\r\n      case 'Home':\r\n        event.preventDefault();\r\n        this.focusByIndex(this.findNextEnabledIndex(0, 1));\r\n        break;\r\n      case 'End':\r\n        event.preventDefault();\r\n        this.focusByIndex(this.findNextEnabledIndex(this.tabs.length - 1, -1));\r\n        break;\r\n      default:\r\n        break;\r\n    }\r\n  }\r\n\r\n  trackByValue(index: number, tab: TabItem): any {\r\n    return tab.value ?? index;\r\n  }\r\n\r\n  get variantClass(): string {\r\n    return `app-tab--${this.variant}`;\r\n  }\r\n\r\n  getTabIndex(tab: TabItem, index: number): number {\r\n    if (tab.disabled) {\r\n      return -1;\r\n    }\r\n    return this.isActive(tab) || (this.active === undefined && index === 0) ? 0 : -1;\r\n  }\r\n\r\n  private focusSibling(currentIndex: number, direction: 1 | -1): void {\r\n    const nextIndex = this.findNextEnabledIndex(currentIndex + direction, direction);\r\n    if (nextIndex !== undefined) {\r\n      this.focusByIndex(nextIndex);\r\n      return;\r\n    }\r\n\r\n    const wrapStart = direction > 0 ? 0 : this.tabs.length - 1;\r\n    const wrappedIndex = this.findNextEnabledIndex(wrapStart, direction);\r\n    this.focusByIndex(wrappedIndex);\r\n  }\r\n\r\n  private focusByIndex(index: number | undefined): void {\r\n    if (index === undefined || index < 0 || index >= this.tabs.length) {\r\n      return;\r\n    }\r\n\r\n    const button = this.tabButtons?.get(index);\r\n    button?.nativeElement.focus();\r\n  }\r\n\r\n  private findNextEnabledIndex(startIndex: number, direction: 1 | -1): number | undefined {\r\n    if (this.tabs.length === 0) {\r\n      return undefined;\r\n    }\r\n\r\n    let index = startIndex;\r\n    while (index >= 0 && index < this.tabs.length) {\r\n      if (!this.tabs[index].disabled) {\r\n        return index;\r\n      }\r\n      index += direction;\r\n    }\r\n\r\n    return undefined;\r\n  }\r\n}\r\n'@; $utf8NoBom = New-Object System.Text.UTF8Encoding $false; [System.IO.File]::WriteAllText('projects/my-shared-lib/src/lib/shared/components/block/tab/tab.component.ts', $content.TrimStart(\"`r\",\"`n\"), $utf8NoBom)"]})
