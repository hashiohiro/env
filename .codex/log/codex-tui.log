[2m2025-09-23T06:02:22.554667Z[0m [32m INFO[0m FunctionCall: shell({"command":["powershell.exe","-Command","Set-Content","projects/my-shared-lib/src/lib/shared/components/control/segmented-control/segmented-control.component.ts","\nimport { Component, Input, Output, EventEmitter } from '@angular/core';\nimport { InputControlComponentBase } from '../../../../core/framework/input-control-component-base';\nimport { SelectOption } from '../select-input/select-input.component';\n\nexport type SegmentedControlVariant = 'primary' | 'secondary' | 'default' | 'danger' | 'success' | 'warning' | 'status';\nexport type SegmentedControlSize = 'xs' | 'sm' | 'md' | 'lg';\n\n/**\n * セグメント化されたコントロール（Segmented Controls）を提供するコンポーネントです。\n * iOS風のセグメンテッドコントロールスタイルでフォームコントロールに対応しています。\n */\n@Component({\n  selector: 'app-segmented-control',\n  templateUrl: './segmented-control.component.html',\n  styleUrl: './segmented-control.component.scss'\n})\nexport class SegmentedControlComponent extends InputControlComponentBase {\n\n  /** 選択肢のオプション配列 */\n  @Input() options: SelectOption[] = [];\n\n  /** バリアント（色の種類） */\n  @Input() variant: SegmentedControlVariant = 'primary';\n\n  /** サイズ */\n  @Input() size: SegmentedControlSize = 'md';\n\n  /** FormFieldGroup を使用するかどうか。false の場合はラッパーを使用せず、単体で表示する。 */\n  @Input() useFormFieldGroup = true;\n\n  /** 上パディングを指定します（px 単位、CSS 文字列、または 'none'）。 */\n  @Input() paddingTop?: number | string | 'none';\n\n  /** 右パディングを指定します（px 単位、CSS 文字列、または 'none'）。 */\n  @Input() paddingRight?: number | string | 'none';\n\n  /** 下パディングを指定します（px 単位、CSS 文字列、または 'none'）。 */\n  @Input() paddingBottom?: number | string | 'none';\n\n  /** 左パディングを指定します（px 単位、CSS 文字列、または 'none'）。 */\n  @Input() paddingLeft?: number | string | 'none';\n\n  /** 値変更時のイベント */\n  @Output() valueChange = new EventEmitter<any>();\n\n  /**\n   * オプション選択時のハンドラ\n   */\n  onOptionSelect(value: any): void {\n    if (this.disabled || this.readonly) {\n      return;\n    }\n\n    if (this.control) {\n      this.control.setValue(value);\n      this.control.markAsTouched();\n    }\n    \n    this.valueChange.emit(value);\n  }\n\n  /**\n   * キーボードイベントのハンドラ\n   */\n  onKeyDown(event: KeyboardEvent, value: any): void {\n    if (event.key === ' ' || event.key === 'Enter') {\n      event.preventDefault();\n      this.onOptionSelect(value);\n    }\n  }\n\n  /**\n   * variantごとのTailwindクラス設定\n   */\n  private readonly variantConfig = {\n    primary: 'primary',\n    secondary: 'secondary', \n    default: 'default',\n    danger: 'danger',\n    success: 'success',\n    warning: 'warning',\n    status: 'status-bg'\n  };\n\n  /**\n   * バリアントに応じたCSSクラスを取得\n   */\n  get variantClass(): string {\n    return `segmented-control--${this.variant}`;\n  }\n\n  /**\n   * サイズに応じたCSSクラスを取得\n   */\n  get sizeClass(): string {\n    return `segmented-control--${this.size}`;\n  }\n\n  /**\n   * TailwindのCSS変数からvariantの実際の色値を取得します。\n   */\n  private getVariantColor(variant: string): string {\n    if (typeof document === 'undefined') {\n      return '#000000'; // SSR時のフォールバック\n    }\n\n    const colorClass = this.variantConfig[variant as keyof typeof this.variantConfig];\n    if (!colorClass) {\n      return '#000000';\n    }\n\n    // 一時的なdivを作成してTailwindの色を取得\n    const tempDiv = document.createElement('div');\n    tempDiv.className = `bg-${colorClass}`;\n    tempDiv.style.visibility = 'hidden';\n    tempDiv.style.position = 'absolute';\n    document.body.appendChild(tempDiv);\n    \n    const computedStyle = window.getComputedStyle(tempDiv);\n    const backgroundColor = computedStyle.backgroundColor;\n    \n    document.body.removeChild(tempDiv);\n    \n    // RGB値をHEX値に変換\n    return this.rgbToHex(backgroundColor) || '#000000';\n  }\n\n  /**\n   * RGB値をHEX値に変換します。\n   */\n  private rgbToHex(rgb: string): string | null {\n    const result = rgb.match(/\\d+/g);\n    if (!result || result.length < 3) {\n      return null;\n    }\n    \n    const r = parseInt(result[0]);\n    const g = parseInt(result[1]);\n    const b = parseInt(result[2]);\n    \n    return '#' + [r, g, b].map(x => {\n      const hex = x.toString(16);\n      return hex.length === 1 ? '0' + hex : hex;\n    }).join('');\n  }\n\n  /**\n   * variantに基づいてボーダー色を返します。\n   */\n  getVariantBorderColor(): string {\n    return this.getVariantColor(this.variant);\n  }\n\n  /**\n   * variant に基づいて選択状態の背景色を返します。\n   */\n  getVariantBackgroundColor(): string {\n    return this.getVariantColor(this.variant);\n  }\n\n  /**\n   * 選択状態に応じた動的クラスを返します。\n   */\n  getSelectedClasses(option: SelectOption | string): { [key: string]: boolean } {\n    const isSelected = this.isSelected(this.getOptionValue(option));\n    \n    if (!isSelected) {\n      return {};\n    }\n\n    const baseClasses: { [key: string]: boolean } = {\n      'selected': true\n    };\n\n    // variantに応じた背景色クラス\n    if (this.variant === 'status') {\n      baseClasses['bg-status-bg'] = true;\n      baseClasses['text-black'] = true;\n    } else {\n      const bgClass = `bg-${this.variant}`;\n      baseClasses[bgClass] = true;\n      baseClasses['text-white'] = true;\n    }\n\n    return baseClasses;\n  }\n\n  /**\n   * 指定された値が現在選択されているかどうか\n   */\n  isSelected(value: any): boolean {\n    return this.control?.value === value;\n  }\n\n  /**\n   * オプションのラベルを取得（文字列またはオブジェクト対応）\n   */\n  getOptionLabel(option: SelectOption | string): string {\n    if (typeof option === 'string') {\n      return option;\n    }\n    return option.label || String(option.value);\n  }\n\n  /**\n   * オプションの値を取得（文字列またはオブジェクト対応）\n   */\n  getOptionValue(option: SelectOption | string): any {\n    if (typeof option === 'string') {\n      return option;\n    }\n    return option.value;\n  }\n\n  /**\n   * オプションが無効化されているかチェック\n   */\n  isOptionDisabled(option: SelectOption | string): boolean {\n    if (typeof option === 'string') {\n      return false;\n    }\n    return option.disabled || false;\n  }\n\n  /**\n   * オプションの最小幅を取得\n   */\n  getOptionMinWidth(option: SelectOption | string): number | undefined {\n    if (typeof option === 'string') {\n      return undefined;\n    }\n    return option.minWidth;\n  }\n\n  /**\n   * ngForのtrackBy関数\n   */\n  trackByOptionValue = (index: number, option: SelectOption | string): any => {\n    return this.getOptionValue(option);\n  }\n\n  /**\n   * コンテナに適用するインラインスタイル文字列を生成する。\n   * useFormFieldGroup が true の場合は margin を除外し、padding のみを適用する。\n   */\n  getControlStyles(): string {\n    const styles: string[] = [];\n\n    const format = (value?: number | string | 'none'): string | undefined => {\n      if (value === undefined || value === 'none') {\n        return undefined;\n      }\n      return typeof value === 'number' ? `${value}px` : value;\n    };\n\n    const includeMargin = !this.useFormFieldGroup;\n\n    if (includeMargin) {\n      const top = format(this.marginTop);\n      const right = format(this.marginRight);\n      const bottom = format(this.marginBottom);\n      const left = format(this.marginLeft);\n\n      if (top) {\n        styles.push(`margin-top: ${top} !important`);\n      }\n      if (right) {\n        styles.push(`margin-right: ${right} !important`);\n      }\n      if (bottom) {\n        styles.push(`margin-bottom: ${bottom} !important`);\n      }\n      if (left) {\n        styles.push(`margin-left: ${left} !important`);\n      }\n    }\n\n    const paddingTop = format(this.paddingTop);\n    const paddingRight = format(this.paddingRight);\n    const paddingBottom = format(this.paddingBottom);\n    const paddingLeft = format(this.paddingLeft);\n\n    if (paddingTop) {\n      styles.push(`padding-top: ${paddingTop} !重要`);\n    }\n    if (paddingRight) {\n      styles.push(`padding-right: ${paddingRight} !重要`);\n    }\n    if (paddingBottom) {\n      styles.push(`padding-bottom: ${paddingBottom} !重要`);\n    }\n    if (paddingLeft) {\n      styles.push(`padding-left: ${paddingLeft} !重要`);\n    }\n\n    return styles.join('; ');\n  }\n}\n"],"workdir":"C:\\Users\\hashi\\WebstormProjects\\Mypage_Front_Project"})
