[2m2025-09-23T09:10:58.351472Z[0m [32m INFO[0m FunctionCall: shell({"command":["powershell.exe","-Command","Set-Content -Path projects/my-features-lib/src/lib/my-kf/pages/usage-information/components/usage-tab-item/usage-tab-item.component.ts -Encoding UTF8 -Value @'\r\nimport { AfterViewInit, Component, Input, NgZone, OnDestroy, OnInit } from '@angular/core';\r\n\r\ntype UsageView = 'monthly' | 'daily' | 'hourly';\r\n\r\ninterface UsageTabOption {\r\n  label: string;\r\n  value: UsageView;\r\n  minWidth?: number;\r\n  disabled?: boolean;\r\n  ariaLabel?: string;\r\n  ariaDescribedby?: string;\r\n  ariaControls?: string;\r\n}\r\n\r\n@Component({\r\n  selector: 'app-usage-tab-item',\r\n  templateUrl: './usage-tab-item.component.html',\r\n  styleUrl: './usage-tab-item.component.scss'\r\n})\r\nexport class UsageTabItemComponent implements OnInit, AfterViewInit, OnDestroy {\r\n  @Input() data?: any[];\r\n  @Input() activeIndex?: number;\r\n\r\n  readonly viewOptions: UsageTabOption[] = [\r\n    { label: '月次', value: 'monthly' },\r\n    { label: '日次', value: 'daily' },\r\n    { label: '時間帯', value: 'hourly' }\r\n  ];\r\n\r\n  selectedView: UsageView = 'monthly';\r\n\r\n  private readonly chartFunctionMap: Record<UsageView, string> = {\r\n    monthly: 'createChart01',\r\n    daily: 'createChart02',\r\n    hourly: 'createChart03'\r\n  };\r\n\r\n  private chartTimerId: number | null = null;\r\n\r\n  constructor(private readonly ngZone: NgZone) {}\r\n\r\n  ngOnInit(): void {\r\n    this.scheduleChartRender(this.selectedView);\r\n  }\r\n\r\n  ngAfterViewInit(): void {\r\n    this.scheduleChartRender(this.selectedView);\r\n  }\r\n\r\n  ngOnDestroy(): void {\r\n    this.clearScheduledChart();\r\n  }\r\n\r\n  onTabChange(view: UsageView): void {\r\n    if (this.selectedView === view) {\r\n      return;\r\n    }\r\n\r\n    this.selectedView = view;\r\n    this.scheduleChartRender(view);\r\n  }\r\n\r\n  private scheduleChartRender(view: UsageView): void {\r\n    if (typeof window === 'undefined') {\r\n      return;\r\n    }\r\n\r\n    this.clearScheduledChart();\r\n\r\n    const functionName = this.chartFunctionMap[view];\r\n    if (!functionName) {\r\n      return;\r\n    }\r\n\r\n    this.chartTimerId = window.setTimeout(() => {\r\n      this.invokeChartFunction(functionName);\r\n    }, 0);\r\n  }\r\n\r\n  private clearScheduledChart(): void {\r\n    if (typeof window === 'undefined') {\r\n      return;\r\n    }\r\n\r\n    if (this.chartTimerId !== null) {\r\n      window.clearTimeout(this.chartTimerId);\r\n      this.chartTimerId = null;\r\n    }\r\n  }\r\n\r\n  private invokeChartFunction(functionName: string): void {\r\n    if (typeof window === 'undefined') {\r\n      return;\r\n    }\r\n\r\n    const chartFunction = (window as unknown as Record<string, unknown>)[functionName];\r\n    if (typeof chartFunction !== 'function') {\r\n      return;\r\n    }\r\n\r\n    this.ngZone.runOutsideAngular(() => {\r\n      try {\r\n        (chartFunction as () => void)();\r\n      } catch (error) {\r\n        console.error(`[UsageTabItem] Failed to execute ${functionName}`, error);\r\n      }\r\n    });\r\n  }\r\n}\r\n'@"]})
