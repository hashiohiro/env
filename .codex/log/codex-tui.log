[2m2025-09-23T09:48:25.098845Z[0m [32m INFO[0m FunctionCall: shell({"command":["powershell.exe","-Command","Set-Content -Path projects/my-features-lib/src/lib/my-kf/pages/usage-information/components/usage-tab/usage-tab.component.ts -Encoding UTF8 -Value @'\r\nimport { AfterViewInit, Component, Input, NgZone, OnDestroy } from '@angular/core';\r\nimport { TabItem } from 'my-shared-lib';\r\n\r\ntype UsageEnergyTab = 'gas' | 'electric';\r\n\r\n@Component({\r\n  selector: 'app-usage-tab',\r\n  templateUrl: './usage-tab.component.html',\r\n  styleUrl: './usage-tab.component.scss'\r\n})\r\nexport class UsageTabComponent implements AfterViewInit, OnDestroy {\r\n  @Input() data?: any[];\r\n  @Input() activeIndex?: number;\r\n\r\n  readonly energyTabs: TabItem[] = [\r\n    { label: 'ガス', value: 'gas', iconUrl: '/assets/img/icon_vector.png' },\r\n    { label: '電気', value: 'electric', iconUrl: '/assets/img/icon_light.png' }\r\n  ];\r\n\r\n  activeTab: UsageEnergyTab = 'gas';\r\n\r\n  private chartTimerId: number | null = null;\r\n\r\n  constructor(private readonly ngZone: NgZone) {}\r\n\r\n  ngAfterViewInit(): void {\r\n    this.scheduleChartRender(this.activeTab);\r\n  }\r\n\r\n  ngOnDestroy(): void {\r\n    this.clearScheduledChart();\r\n  }\r\n\r\n  onTabChange(tabValue: UsageEnergyTab): void {\r\n    if (this.activeTab === tabValue) {\r\n      return;\r\n    }\r\n\r\n    this.activeTab = tabValue;\r\n    this.scheduleChartRender(tabValue);\r\n  }\r\n\r\n  private scheduleChartRender(tabValue: UsageEnergyTab): void {\r\n    if (typeof window === 'undefined') {\r\n      return;\r\n    }\r\n\r\n    this.clearScheduledChart();\r\n\r\n    const functionName = this.getChartFunctionName(tabValue);\r\n    if (!functionName) {\r\n      return;\r\n    }\r\n\r\n    this.chartTimerId = window.setTimeout(() => {\r\n      this.invokeChartFunction(functionName);\r\n    }, 0);\r\n  }\r\n\r\n  private clearScheduledChart(): void {\r\n    if (typeof window === 'undefined') {\r\n      return;\r\n    }\r\n\r\n    if (this.chartTimerId !== null) {\r\n      window.clearTimeout(this.chartTimerId);\r\n      this.chartTimerId = null;\r\n    }\r\n  }\r\n\r\n  private invokeChartFunction(functionName: string): void {\r\n    if (typeof window === 'undefined') {\r\n      return;\r\n    }\r\n\r\n    const chartFunction = (window as unknown as Record<string, unknown>)[functionName];\r\n    if (typeof chartFunction !== 'function') {\r\n      return;\r\n    }\r\n\r\n    this.ngZone.runOutsideAngular(() => {\r\n      try {\r\n        (chartFunction as () => void)();\r\n      } catch (error) {\r\n        console.error(`[UsageTab] Failed to execute ${functionName}`, error);\r\n      }\r\n    });\r\n  }\r\n\r\n  private getChartFunctionName(tabValue: UsageEnergyTab): string | null {\r\n    switch (tabValue) {\r\n      case 'gas':\r\n        return 'createChart01';\r\n      case 'electric':\r\n        return 'createChart04';\r\n      default:\r\n        return null;\r\n    }\r\n  }\r\n}\r\n'@"]})
