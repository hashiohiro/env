age-tab-padding-right)'\"\n          [paddingBottom]=\"'var(--usage-tab-padding-bottom)'\"\n          [paddingLeft]=\"'var(--usage-tab-padding-left)'\"\n          [marginBottom]=\"'var(--usage-tab-margin-bottom)'\">\n          <div class=\"flex flex-wrap\">\n            <app-text>＜ご契約プラン＞</app-text>\n            <div class=\"amountctBox-select\">\n              <select>\n                <option value=\"\" disabled selected>最大文字数を表示時のダミーテキストです</option>\n                <option value=\"01\">01</option>\n                <option value=\"02\">02</option>\n              </select>\n            </div>\n          </div>\n        </app-card>\n        <app-usage-tab-item></app-usage-tab-item>\n      </div>\n    </div>\n  </div>\n</div>\n'@;\nSet-Content -Path $path -Value $content -Encoding UTF8;"]})
