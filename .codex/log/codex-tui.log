[2m2025-09-23T06:19:49.006134Z[0m [32m INFO[0m FunctionCall: shell({"command":["powershell.exe","-Command","$path='projects/my-features-lib/src/lib/my-kf/pages/usage-information/components/usage-tab/usage-tab.component.ts';\n$enc=New-Object System.Text.UTF8Encoding($false);\n$content=@'\nimport { Component, OnDestroy } from '@angular/core';\nimport { FormControl } from '@angular/forms';\nimport { SelectOption } from 'my-shared-lib';\nimport { Subscription } from 'rxjs';\n\n@Component({\n  selector: 'app-usage-tab',\n  templateUrl: './usage-tab.component.html',\n  styleUrl: './usage-tab.component.scss'\n})\nexport class UsageTabComponent implements OnDestroy {\n  private readonly segmentOptions: SelectOption[] = [\n    { label: 'ガス', value: 'gas' },\n    { label: '電気', value: 'electric' },\n  ];\n\n  private readonly chartMap: Record<string, string> = {\n    gas: 'createChart01',\n    electric: 'createChart04',\n  };\n\n  readonly segmentControl = new FormControl<string>(this.segmentOptions[0].value, { nonNullable: true });\n  readonly segments = this.segmentOptions;\n  activeTab = this.segmentOptions[0].value;\n\n  private readonly segmentSubscription: Subscription;\n\n  constructor() {\n    this.segmentSubscription = this.segmentControl.valueChanges.subscribe((value) => {\n      this.onSegmentChange(value);\n    });\n\n    // 初期表示時にチャートを更新\n    this.invokeChart(this.activeTab);\n  }\n\n  ngOnDestroy(): void {\n    this.segmentSubscription.unsubscribe();\n  }\n\n  onSegmentChange(value: string): void {\n    if (this.activeTab === value) {\n      return;\n    }\n    this.activeTab = value;\n    this.invokeChart(value);\n  }\n\n  private invokeChart(key: string): void {\n    const fnName = this.chartMap[key];\n    if (!fnName) {\n      return;\n    }\n\n    const globalRef = (window as Record<string, unknown>) ?? {};\n    const chartFn = globalRef[fnName];\n\n    if (typeof chartFn === 'function') {\n      (chartFn as () => void)();\n    }\n  }\n}\n'@;\n[System.IO.File]::WriteAllText($path,$content,$enc);"]})
